        "zh-TW": {
          "name": "環境模式",
          "description": ""
        }
      },
      "[\"Ambient mode\",\"Adds options to bypass power saving restrictions for Ambient mode and disable it entirely or in fullscreen.\"]": {
        "zh-TW": {
          "name": "環境模式",
          "description": "新增略過 Ambient mode 省電限制，以及在全域或全螢幕停用它的選項。"
