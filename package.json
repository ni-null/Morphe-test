{
  "name": "patcher-builder",
  "private": true,
  "version": "0.1.0",
  "description": "Auto download APK and patch with engine-cli on Windows",
  "workspaces": [
    "cli",
    "desktop",
    "desktop/web"
  ],
  "scripts": {
    "test:patch-naming": "node ./tests/patch-naming.test.js",
    "test:env-aliases": "node ./tests/env-aliases.test.js",
    "test:providers": "node ./tests/providers.test.js",
    "test:cli-connector": "node ./tests/cli-connector.test.js",
    "report:legacy-aliases": "node ./scripts/ci/report-legacy-aliases.js",
    "report:legacy-aliases:check": "node ./scripts/ci/report-legacy-aliases.js --fail-on-hits",
    "cli:start": "npm run start --workspace patcher-cli",
    "web:dev": "npm run dev --workspace patcher-web-ui",
    "web:ui": "npm run web:dev",
    "web:build": "npm run build --workspace patcher-web-ui",
    "desktop:install": "npm install --workspace patcher-desktop",
    "desktop:dev": "npm run dev --workspace patcher-desktop",
    "desktop:start": "npm run web:build && npm run start --workspace patcher-desktop",
    "desktop:pack": "npm run web:build && npm run pack --workspace patcher-desktop",
    "i18n:patches:zh-TW": "npm run i18n:patches:zh-TW --workspace patcher-web-ui"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "build": {
    "appId": "com.patcher.builder",
    "productName": "APK Patches Studio",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-TW"
    ],
    "extraMetadata": {
      "main": "desktop/main.js"
    },
    "files": [
      "cli/**/*",
      "desktop/main.js",
      "desktop/preload.js",
      "desktop/ipc/**/*",
      "desktop/web/dist/**/*",
      "scripts/**/*",
      "utils/**/*",
      "morphe-test.keystore",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
