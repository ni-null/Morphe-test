{
  "name": "morphe-test",
  "private": true,
  "version": "0.1.0",
  "description": "Auto download APK and patch with morphe-cli on Windows",
  "scripts": {
    "web:ui": "npm --prefix ./web run dev",
    "web:build": "npm --prefix ./web run build",
    "desktop:install": "npm --prefix ./desktop install",
    "desktop:dev": "npm --prefix ./desktop run dev",
    "desktop:start": "npm run web:build && npm --prefix ./desktop run start",
    "desktop:pack": "npm run web:build && npm --prefix ./desktop run pack",
    "i18n:patches:zh-TW": "npm --prefix ./web run i18n:patches:zh-TW"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "build": {
    "appId": "com.morphe.patcher",
    "productName": "Morphe Patcher",
    "extraMetadata": {
      "main": "desktop/main.js"
    },
    "files": [
      "desktop/**/*",
      "web/dist/**/*",
      "main.js",
      "scripts/**/*",
      "utils/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
