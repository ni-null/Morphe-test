{
  "name": "morphe-test",
  "private": true,
  "version": "0.1.0",
  "description": "Auto download APK and patch with morphe-cli on Windows",
  "workspaces": [
    "desktop",
    "desktop/web"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace desktop/web",
    "web:ui": "npm run web:dev",
    "web:build": "npm run build --workspace desktop/web",
    "desktop:install": "npm install --workspace desktop",
    "desktop:dev": "npm run dev --workspace desktop",
    "desktop:start": "npm run web:build && npm run start --workspace desktop",
    "desktop:pack": "npm run web:build && npm run pack --workspace desktop",
    "i18n:patches:zh-TW": "npm run i18n:patches:zh-TW --workspace desktop/web"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "build": {
    "appId": "com.morphe.patcher",
    "productName": "Morphe Patcher",
    "extraMetadata": {
      "main": "desktop/main.js"
    },
    "files": [
      "desktop/**/*",
      "desktop/web/dist/**/*",
      "main.js",
      "scripts/**/*",
      "utils/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
